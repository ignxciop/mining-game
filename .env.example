# ⛏️ Mining Game — Environment Variables
# =============================================================================
# Copy this file to .env and adjust values for your environment
# =============================================================================

# ── Ports ───────────────────────────────────────────────────────────────────
NGINX_PORT=4011
BACKEND_PORT=4012
DB_PORT=5432

# ─── Database (PostgreSQL — future) ─────────────────────────────────────────
DB_USER=mining
DB_PASS=mining
DB_NAME=mining
DATABASE_URL=postgresql://${DB_USER}:${DB_PASS}@db:5432/${DB_NAME}

# ─── Authentication (future) ────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-secret
JWT_EXPIRES_IN=7d

# ─── Cloudflare Tunnel ──────────────────────────────────────────────────────
CLOUDFLARE_TUNNEL_TOKEN=
# ── Dashboard → Public Hostname: Type=HTTP, URL=http://nginx:80

# ─── Node ───────────────────────────────────────────────────────────────────
NODE_ENV=production
